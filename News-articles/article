<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Article — PoGORaids</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,900;1,700&family=Barlow:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:       #08090f;
      --panel:     #10121c;
      --panel-hi:  #14172a;
      --border:    rgba(80,140,255,0.12);
      --border-hi: rgba(80,140,255,0.22);
      --cyan:      #3be8ff;
      --cyan-dim:  #1ab8d4;
      --logo-grad: linear-gradient(135deg, #3be8ff 0%, #7b3fff 55%, #b020ff 100%);
      --text:      #e8eaf0;
      --muted:     #7a82a0;
      --accent:    var(--cyan);
      --font-head: 'Barlow Condensed', sans-serif;
      --font-body: 'Barlow', sans-serif;
      --font-mono: 'Space Mono', monospace;
    }

    html { scroll-behavior: smooth; }
    body {
      background: var(--ink); color: var(--text);
      font-family: var(--font-body); line-height: 1.6; overflow-x: hidden;
    }
    a { text-decoration: none; color: inherit; }

    body::before {
      content: ''; position: fixed; inset: 0;
      background-image:
        linear-gradient(rgba(59,128,255,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(59,128,255,0.04) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none; z-index: 0;
    }

    /* ── NAVBAR ── */
    .navbar {
      position: sticky; top: 0; z-index: 99;
      background: rgba(8,9,15,0.94); backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      padding: 0 40px; height: 64px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo { display: flex; align-items: center; gap: 10px; }
    .nav-logo-img { width: 32px; height: 32px; object-fit: contain; filter: drop-shadow(0 0 8px rgba(123,63,255,0.6)); }
    .nav-title {
      font-family: var(--font-head); font-weight: 900; font-size: 20px;
      letter-spacing: 0.06em; text-transform: uppercase;
      background: var(--logo-grad); -webkit-background-clip: text;
      -webkit-text-fill-color: transparent; background-clip: text;
    }
    .nav-links { list-style: none; display: flex; gap: 28px; align-items: center; }
    .nav-links a {
      font-family: var(--font-head); font-weight: 700; font-size: 14px;
      letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--cyan); }

    /* ── ARTICLE HERO ── */
    .article-hero {
      position: relative; z-index: 1;
      min-height: 420px; display: flex; align-items: flex-end;
      overflow: hidden;
    }

    .article-hero-bg {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, #0d1528, #1a0d2e);
    }

    .article-hero-glow {
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at 30% 50%, rgba(123,63,255,0.2) 0%, transparent 60%);
    }

    .article-hero-emoji {
      position: absolute; right: 80px; top: 50%;
      transform: translateY(-50%);
      font-size: 160px; opacity: 0.12;
      filter: saturate(0.6);
      pointer-events: none;
    }

    /* Progress bar */
    .read-progress {
      position: fixed; top: 0; left: 0; z-index: 200;
      height: 3px; width: 0%;
      background: var(--logo-grad);
      transition: width 0.1s linear;
    }

    .article-hero-content {
      position: relative; z-index: 2;
      padding: 60px 40px 52px; max-width: 900px; width: 100%;
      margin: 0 auto;
    }

    .breadcrumb {
      font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--muted); margin-bottom: 20px;
      display: flex; align-items: center; gap: 8px;
    }
    .breadcrumb a { color: var(--cyan-dim); transition: color 0.2s; }
    .breadcrumb a:hover { color: var(--cyan); }

    .article-category-tag {
      font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.2em;
      text-transform: uppercase; display: inline-flex; align-items: center; gap: 6px;
      padding: 5px 12px; border-radius: 3px; margin-bottom: 18px;
      border: 1px solid; background: rgba(0,0,0,0.4);
    }

    .article-hero-title {
      font-family: var(--font-head); font-weight: 900;
      font-size: clamp(32px, 5vw, 58px); text-transform: uppercase;
      letter-spacing: -0.01em; line-height: 1.0;
      margin-bottom: 20px; color: var(--text);
    }

    .article-hero-meta {
      display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
      font-family: var(--font-mono); font-size: 11px; color: var(--muted);
      letter-spacing: 0.06em;
    }
    .article-hero-meta i { font-size: 10px; margin-right: 5px; }
    .article-hero-meta .sep { opacity: 0.3; }

    .article-tags {
      display: flex; gap: 6px; flex-wrap: wrap; margin-top: 18px;
    }
    .article-tag-pill {
      font-family: var(--font-head); font-weight: 600; font-size: 11px;
      letter-spacing: 0.08em; text-transform: uppercase;
      padding: 4px 10px; border-radius: 3px;
      background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.09);
      color: var(--muted); transition: color 0.2s;
    }
    .article-tag-pill:hover { color: var(--text); }

    /* ── ARTICLE BODY ── */
    .article-layout {
      position: relative; z-index: 1;
      padding: 0 40px 100px; max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 280px; gap: 48px;
      align-items: start;
    }

    .article-body {
      padding-top: 52px;
    }

    /* Rich text styles */
    .article-prose {
      font-size: 17px; line-height: 1.85; color: rgba(232,234,240,0.85);
    }

    .article-prose p { margin-bottom: 1.4em; }

    .article-prose h2 {
      font-family: var(--font-head); font-weight: 900; font-size: 28px;
      text-transform: uppercase; letter-spacing: 0.02em;
      color: var(--text); margin: 2em 0 0.6em;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }

    .article-prose h2::before {
      content: '//';
      font-family: var(--font-mono); font-size: 14px;
      margin-right: 10px; opacity: 0.4;
    }

    .article-prose h3 {
      font-family: var(--font-head); font-weight: 700; font-size: 20px;
      text-transform: uppercase; letter-spacing: 0.04em;
      color: var(--text); margin: 1.6em 0 0.5em;
    }

    .article-prose ul, .article-prose ol {
      padding-left: 0; list-style: none; margin-bottom: 1.4em;
    }

    .article-prose ul li, .article-prose ol li {
      padding: 8px 0 8px 20px; position: relative;
      border-bottom: 1px solid rgba(80,140,255,0.06);
      font-size: 16px;
    }

    .article-prose ul li::before {
      content: '';
      position: absolute; left: 0; top: 50%;
      transform: translateY(-50%);
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--accent, var(--cyan));
    }

    .article-prose ol { counter-reset: ol-counter; }
    .article-prose ol li { counter-increment: ol-counter; }
    .article-prose ol li::before {
      content: counter(ol-counter);
      position: absolute; left: 0; top: 8px;
      font-family: var(--font-mono); font-size: 10px;
      color: var(--accent, var(--cyan)); font-weight: 700;
    }

    .article-prose strong { color: var(--text); font-weight: 600; }

    .article-prose a {
      color: var(--accent, var(--cyan)); border-bottom: 1px solid transparent;
      transition: border-color 0.2s;
    }
    .article-prose a:hover { border-color: var(--accent, var(--cyan)); }

    .article-prose blockquote {
      border-left: 3px solid var(--accent, var(--cyan));
      background: rgba(59,232,255,0.04); padding: 16px 20px;
      margin: 1.4em 0; border-radius: 0 4px 4px 0;
      font-style: italic; color: var(--muted);
    }

    .article-prose code {
      font-family: var(--font-mono); font-size: 13px;
      background: rgba(255,255,255,0.06); padding: 2px 7px;
      border-radius: 3px; color: var(--cyan);
    }

    /* Share / nav footer */
    .article-footer {
      margin-top: 60px; padding-top: 32px; border-top: 1px solid var(--border);
    }

    .article-footer-nav {
      display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 32px;
    }

    .article-nav-btn {
      background: var(--panel); border: 1px solid var(--border); border-radius: 6px;
      padding: 16px 20px; cursor: pointer; transition: border-color 0.2s;
      display: flex; flex-direction: column; gap: 4px;
    }
    .article-nav-btn:hover { border-color: var(--border-hi); }
    .article-nav-btn.next { text-align: right; }

    .nav-btn-label {
      font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.15em;
      text-transform: uppercase; color: var(--muted);
    }
    .nav-btn-title {
      font-family: var(--font-head); font-weight: 700; font-size: 15px;
      text-transform: uppercase; letter-spacing: 0.03em; color: var(--text);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .nav-btn-tag { font-family: var(--font-mono); font-size: 10px; }

    .share-row {
      display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    }
    .share-label {
      font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.15em;
      text-transform: uppercase; color: var(--muted);
    }
    .share-btn {
      background: var(--panel); border: 1px solid var(--border); color: var(--muted);
      font-family: var(--font-head); font-weight: 700; font-size: 12px;
      letter-spacing: 0.08em; text-transform: uppercase;
      padding: 8px 16px; border-radius: 4px; cursor: pointer;
      display: flex; align-items: center; gap: 6px; transition: all 0.2s;
    }
    .share-btn:hover { color: var(--cyan); border-color: rgba(59,232,255,0.3); }

    /* ── STICKY SIDEBAR ── */
    .article-sidebar { position: sticky; top: 84px; padding-top: 52px; }

    /* TOC */
    .toc-card {
      background: var(--panel); border: 1px solid var(--border);
      border-radius: 8px; padding: 20px; margin-bottom: 16px;
    }
    .toc-title {
      font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.25em;
      text-transform: uppercase; color: var(--muted); margin-bottom: 14px;
    }
    .toc-item {
      font-family: var(--font-head); font-weight: 700; font-size: 13px;
      letter-spacing: 0.04em; text-transform: uppercase;
      color: var(--muted); padding: 7px 0; border-bottom: 1px solid var(--border);
      cursor: pointer; transition: color 0.2s;
      display: flex; align-items: center; gap: 8px;
    }
    .toc-item:last-child { border-bottom: none; }
    .toc-item:hover { color: var(--text); }
    .toc-item.active { color: var(--accent); }
    .toc-item .toc-num {
      font-family: var(--font-mono); font-size: 9px; color: var(--muted);
      width: 16px; flex-shrink: 0;
    }

    /* Related */
    .related-card {
      background: var(--panel); border: 1px solid var(--border);
      border-radius: 8px; overflow: hidden; margin-bottom: 10px;
      cursor: pointer; transition: border-color 0.2s;
      display: flex; flex-direction: column;
    }
    .related-card:hover { border-color: var(--border-hi); }
    .related-card-thumb {
      height: 80px; display: flex; align-items: center; justify-content: center;
      font-size: 32px; position: relative; overflow: hidden;
    }
    .related-card-body { padding: 12px 14px; }
    .related-tag { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 4px; }
    .related-title {
      font-family: var(--font-head); font-weight: 700; font-size: 14px;
      text-transform: uppercase; letter-spacing: 0.03em; line-height: 1.2;
      color: var(--text); display: -webkit-box; -webkit-line-clamp: 2;
      -webkit-box-orient: vertical; overflow: hidden;
    }
    .related-meta { font-family: var(--font-mono); font-size: 9px; color: var(--muted); margin-top: 5px; }

    /* ── BACK TO TOP ── */
    .back-top {
      position: fixed; bottom: 32px; right: 32px; z-index: 50;
      background: var(--panel); border: 1px solid var(--border-hi);
      color: var(--muted); width: 44px; height: 44px; border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; font-size: 16px;
      transition: color 0.2s, border-color 0.2s, opacity 0.3s, transform 0.3s;
      opacity: 0; transform: translateY(12px); pointer-events: none;
    }
    .back-top.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
    .back-top:hover { color: var(--cyan); border-color: var(--cyan-dim); }

    /* ── FOOTER ── */
    footer {
      position: relative; z-index: 1; border-top: 1px solid var(--border);
      padding: 24px 40px; display: flex; align-items: center; justify-content: space-between;
    }
    .footer-logo {
      font-family: var(--font-head); font-weight: 900; font-size: 15px;
      letter-spacing: 0.08em; text-transform: uppercase;
      background: var(--logo-grad); -webkit-background-clip: text;
      -webkit-text-fill-color: transparent; background-clip: text;
    }
    footer p { font-family: var(--font-mono); font-size: 10px; color: var(--muted); letter-spacing: 0.05em; }

    /* ── NOT FOUND ── */
    .not-found {
      position: relative; z-index: 1; text-align: center;
      padding: 120px 40px; color: var(--muted);
    }
    .not-found i { font-size: 48px; margin-bottom: 16px; display: block; opacity: 0.3; }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) { .article-layout { grid-template-columns: 1fr; } .article-sidebar { position: static; } }
    @media (max-width: 768px) {
      .navbar { padding: 0 20px; }
      .article-hero-content, .article-layout, footer { padding-left: 20px; padding-right: 20px; }
      .article-hero-emoji { display: none; }
      .article-footer-nav { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <div class="read-progress" id="read-progress"></div>

  <nav class="navbar">
    <a href="index.html" class="nav-logo">
      <img src="assets/logo.png" alt="PoGORaids" class="nav-logo-img" onerror="this.style.display='none'" />
      <span class="nav-title">PoGORaids</span>
    </a>
    <ul class="nav-links">
      <li><a href="index.html#tools">Tools</a></li>
      <li><a href="news.html">News</a></li>
      <li><a href="events.html">Calendar</a></li>
      <li><a href="https://discord.gg/pogoraids" target="_blank" rel="noopener" style="color:#fff;background:#5865F2;padding:6px 16px;border-radius:4px;font-size:13px;">Discord</a></li>
    </ul>
  </nav>

  <div id="article-root"></div>

  <button class="back-top" id="back-top"><i class="fa-solid fa-chevron-up"></i></button>

  <footer>
    <span class="footer-logo">PoGORaids</span>
    <p>© 2026 PoGORaids.net — Not affiliated with Niantic or Pokémon GO.</p>
  </footer>

  <script src="news-data.js"></script>
  <script>
    function getSlug() {
      return new URLSearchParams(window.location.search).get('slug') || '';
    }

    function getCatColor(cat) { return NEWS_CATEGORIES[cat]?.color || '#3be8ff'; }
    function getCatLabel(cat) { return NEWS_CATEGORIES[cat]?.label || cat; }
    function getCatIcon(cat)  { return NEWS_CATEGORIES[cat]?.icon || 'fa-circle'; }

    function formatDate(str) {
      const [y,m,d] = str.split('-').map(Number);
      return new Date(y,m-1,d).toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
    }

    function buildTOC(html) {
      const tmp = document.createElement('div');
      tmp.innerHTML = html;
      const headings = tmp.querySelectorAll('h2,h3');
      return Array.from(headings).map((h, i) => ({
        id: `heading-${i}`,
        text: h.textContent.replace(/^\/\//,'').trim(),
        level: h.tagName
      }));
    }

    function addHeadingIds(html, toc) {
      let i = 0;
      return html.replace(/<(h[23])[^>]*>([\s\S]*?)<\/h[23]>/g, (match, tag, content) => {
        const id = toc[i]?.id || `heading-${i}`;
        i++;
        return `<${tag} id="${id}">${content}</${tag}>`;
      });
    }

    function render() {
      const slug    = getSlug();
      const article = POGORAIDS_ARTICLES.find(a => a.slug === slug);
      const root    = document.getElementById('article-root');

      if (!article) {
        root.innerHTML = `
          <div class="not-found">
            <i class="fa-solid fa-file-circle-xmark"></i>
            <div style="font-family:var(--font-head);font-size:32px;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:10px">Article Not Found</div>
            <div style="font-size:15px;margin-bottom:24px">The article you're looking for doesn't exist.</div>
            <a href="news.html" style="font-family:var(--font-head);font-weight:700;font-size:14px;letter-spacing:0.1em;text-transform:uppercase;color:var(--cyan);border:1px solid rgba(59,232,255,0.3);padding:12px 28px;border-radius:4px">← Back to News</a>
          </div>`;
        return;
      }

      // Set page title & accent
      document.title = `${article.title} — PoGORaids`;
      document.documentElement.style.setProperty('--accent', article.accentColor || 'var(--cyan)');

      const col    = getCatColor(article.category);
      const toc    = buildTOC(article.body);
      const body   = addHeadingIds(article.body, toc);

      // Related articles
      const related = POGORAIDS_ARTICLES
        .filter(a => a.slug !== slug)
        .filter(a => a.category === article.category || (article.tags||[]).some(t => (a.tags||[]).includes(t)))
        .slice(0,3);

      // Prev / next
      const idx  = POGORAIDS_ARTICLES.findIndex(a => a.slug === slug);
      const prev = POGORAIDS_ARTICLES[idx-1];
      const next = POGORAIDS_ARTICLES[idx+1];

      root.innerHTML = `
        <!-- HERO -->
        <div class="article-hero">
          <div class="article-hero-bg" style="background:${article.heroGradient}"></div>
          <div class="article-hero-glow" style="background:radial-gradient(ellipse at 30% 50%, ${col}30 0%, transparent 60%)"></div>
          <div class="article-hero-emoji">${article.emoji}</div>
          <div class="article-hero-content">
            <div class="breadcrumb">
              <a href="index.html">Home</a> <span>/</span>
              <a href="news.html">News</a> <span>/</span>
              <span>${article.tag}</span>
            </div>
            <div class="article-category-tag" style="color:${col};border-color:${col}55">
              <i class="fa-solid ${getCatIcon(article.category)}" style="font-size:9px"></i>
              ${article.tag}
            </div>
            <h1 class="article-hero-title">${article.title}</h1>
            <div class="article-hero-meta">
              <span><i class="fa-solid fa-user"></i>${article.author}</span>
              <span class="sep">|</span>
              <span><i class="fa-solid fa-calendar"></i>${formatDate(article.date)}</span>
              <span class="sep">|</span>
              <span><i class="fa-solid fa-clock"></i>${article.readTime} min read</span>
            </div>
            <div class="article-tags">
              ${(article.tags||[]).map(t => `<span class="article-tag-pill">${t}</span>`).join('')}
            </div>
          </div>
        </div>

        <!-- BODY + SIDEBAR -->
        <div class="article-layout">
          <article class="article-body">
            <div class="article-prose">${body}</div>

            <div class="article-footer">
              <div class="article-footer-nav">
                ${prev ? `
                  <div class="article-nav-btn" onclick="location.href='article.html?slug=${prev.slug}'">
                    <div class="nav-btn-label">← Previous</div>
                    <div class="nav-btn-title">${prev.title}</div>
                    <div class="nav-btn-tag" style="color:${getCatColor(prev.category)}">${prev.tag}</div>
                  </div>` : '<div></div>'}
                ${next ? `
                  <div class="article-nav-btn next" onclick="location.href='article.html?slug=${next.slug}'">
                    <div class="nav-btn-label">Next →</div>
                    <div class="nav-btn-title">${next.title}</div>
                    <div class="nav-btn-tag" style="color:${getCatColor(next.category)}">${next.tag}</div>
                  </div>` : '<div></div>'}
              </div>
              <div class="share-row">
                <span class="share-label">Share:</span>
                <button class="share-btn" onclick="copyLink()"><i class="fa-solid fa-link"></i> Copy Link</button>
                <button class="share-btn" onclick="shareTwitter()"><i class="fa-brands fa-x-twitter"></i> Post</button>
                <button class="share-btn" onclick="shareDiscord()"><i class="fa-brands fa-discord"></i> Discord</button>
              </div>
            </div>
          </article>

          <aside class="article-sidebar">
            ${toc.length > 0 ? `
              <div class="toc-card">
                <div class="toc-title">// Contents</div>
                ${toc.map((item, i) => `
                  <div class="toc-item" id="toc-${item.id}" onclick="scrollTo(document.getElementById('${item.id}'))">
                    <span class="toc-num">${String(i+1).padStart(2,'0')}</span>
                    ${item.text}
                  </div>`).join('')}
              </div>` : ''}

            ${related.length > 0 ? `
              <div style="font-family:var(--font-mono);font-size:9px;letter-spacing:0.25em;text-transform:uppercase;color:var(--muted);margin-bottom:10px">Related Articles</div>
              ${related.map(r => `
                <div class="related-card" onclick="location.href='article.html?slug=${r.slug}'">
                  <div class="related-card-thumb" style="background:${r.heroGradient}">
                    <span style="position:relative;z-index:1;font-size:32px;opacity:0.5">${r.emoji}</span>
                  </div>
                  <div class="related-card-body">
                    <div class="related-tag" style="color:${getCatColor(r.category)}">${r.tag}</div>
                    <div class="related-title">${r.title}</div>
                    <div class="related-meta">${r.readTime} min · ${r.date}</div>
                  </div>
                </div>`).join('')}` : ''}
          </aside>
        </div>`;

      // TOC scroll spy
      const tocItems  = toc.map(t => document.getElementById(t.id)).filter(Boolean);
      const tocLinks  = toc.map(t => document.getElementById(`toc-${t.id}`)).filter(Boolean);

      window.addEventListener('scroll', () => {
        let current = 0;
        tocItems.forEach((el, i) => {
          if (el && el.getBoundingClientRect().top < 120) current = i;
        });
        tocLinks.forEach((l,i) => l?.classList.toggle('active', i === current));

        // Progress bar
        const el    = document.documentElement;
        const pct   = (el.scrollTop / (el.scrollHeight - el.clientHeight)) * 100;
        document.getElementById('read-progress').style.width = pct + '%';
      });
    }

    // Share functions
    function copyLink() {
      navigator.clipboard.writeText(window.location.href)
        .then(() => { const b = event.target.closest('.share-btn'); const orig = b.innerHTML; b.innerHTML = '<i class="fa-solid fa-check"></i> Copied!'; setTimeout(() => b.innerHTML = orig, 1800); });
    }
    function shareTwitter() {
      const slug = getSlug();
      const a    = POGORAIDS_ARTICLES.find(x => x.slug === slug);
      window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent((a?.title||'') + ' — via @PoGORaids')}&url=${encodeURIComponent(window.location.href)}`,'_blank');
    }
    function shareDiscord() { window.open('https://discord.gg/pogoraids','_blank'); }

    function scrollTo(el) { if (el) el.scrollIntoView({behavior:'smooth', block:'start'}); }

    const backTop = document.getElementById('back-top');
    window.addEventListener('scroll', () => backTop.classList.toggle('visible', window.scrollY > 300));
    backTop.addEventListener('click', () => window.scrollTo({top:0,behavior:'smooth'}));

    render();
  </script>
</body>
</html>
