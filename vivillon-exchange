        { value: 'full', weight: 15 }
      ];
      const weightedStatuses = [];
      statuses.forEach(s => { for (let i = 0; i < s.weight; i++) weightedStatuses.push(s.value); });

      for (let i = 0; i < count; i++) {
        const homeRegion = randomFrom(weightedRegions);
        const lookingFor = randomSubset(regionNames.filter(r => r !== homeRegion), 2, 4);
        const minutesAgo = Math.floor(Math.random() * 10080);
        const createdAt = now - Math.floor(Math.random() * 90) * 24 * 60 * 60 * 1000;
        
        trainers.push({
          id: 't_' + i,
          username: trainerNames[i % trainerNames.length] + (i >= trainerNames.length ? Math.floor(i / trainerNames.length) : ''),
          friendCode: generateFriendCode(),
          homeRegion,
          lookingFor,
          country: randomFrom(countryPool), // Replaced languages with country
          status: randomFrom(weightedStatuses),
          lastSeen: now - minutesAgo * 60 * 1000,
          createdAt,
          completedExchanges: Math.floor(Math.random() * 50),
          avatarColor: vivillonRegions[homeRegion].c1,
          avatarInitial: trainerNames[i % trainerNames.length][0].toUpperCase()
        });
      }
      return trainers;
    }

    /* ============================================================
       STATE
       ============================================================ */
    const state = {
      myProfile: {
        friendCode: '1234 5678 9012',
        username: 'MyTrainer',
        homeRegion: 'Meadow',
        lookingFor: ['Ocean', 'Sun', 'Sandstorm'],
        status: 'available',
        country: 'United States'
      },
      trainers: [],
      filters: { search: '', regions: [], sort: 'recently-active' },
      sentRequests: new Set(),
      currentPage: 1,
      perPage: 9,
      completedRegions: new Set(['Meadow', 'Modern'])
    };

    /* ============================================================
       UTILITIES
       ============================================================ */
    function debounce(fn, delay) {
      let timer;
      return function(...args) {
        clearTimeout(timer);
        timer = setTimeout(() => fn.apply(this, args), delay);
      };
    }

    function formatLastSeen(timestamp) {
      const diff = Date.now() - timestamp;
      const minutes = Math.floor(diff / 60000);
      if (minutes < 1) return 'Just now';
      if (minutes < 60) return `${minutes} min ago`;
      const hours = Math.floor(minutes / 60);
      if (hours < 24) return `${hours} hr ago`;
      const days = Math.floor(hours / 24);
      if (days < 7) return `${days} day${days > 1 ? 's' : ''} ago`;
      const weeks = Math.floor(days / 7);
      return `${weeks} week${weeks > 1 ? 's' : ''} ago`;
    }

    function statusLabel(status) {
      return { available: 'Available', away: 'Away', full: 'Full' }[status] || status;
    }

    /* ============================================================
       TOAST SYSTEM
       ============================================================ */
    function showToast(message, type = 'info') {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      toast.className = `toast ${type}`;
      const icons = {
        success: '<i class="fa-solid fa-check-circle toast-icon"></i>',
        error: '<i class="fa-solid fa-times-circle toast-icon"></i>',
        info: '<i class="fa-solid fa-info-circle toast-icon"></i>'
      };
      toast.innerHTML = `${icons[type] || icons.info}<span style="font-size: 13px; font-weight: 500;">${message}</span>`;
      container.appendChild(toast);
      setTimeout(() => {
        toast.style.animation = 'slideIn 0.3s ease reverse';
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    async function copyToClipboard(text, label = 'Copied to clipboard!') {
      try {
        await navigator.clipboard.writeText(text);
        showToast(label, 'success');
      } catch (err) {
        const textArea = document.createElement('textarea');
        textArea.value = text;
        document.body.appendChild(textArea);
        textArea.select();
        try { document.execCommand('copy'); showToast(label, 'success'); } catch (e) { showToast('Failed to copy', 'error'); }
        document.body.removeChild(textArea);
      }
    }

    /* ============================================================
       RENDER FUNCTIONS
       ============================================================ */
    function populateRegionSelects() {
      const myRegion = document.getElementById('myRegion');
      myRegion.innerHTML = regionNames.map(r => `<option value="${r}" ${r === state.myProfile.homeRegion ? 'selected' : ''}>${r}</option>`).join('');
    }

    function renderMultiSelect(containerId, selectedValues) {
      const container = document.getElementById(containerId);
      container.innerHTML = regionNames.map(region => {
        const selected = selectedValues.includes(region);
        return `
          <div class="multiselect-option ${selected ? 'selected' : ''}" data-region="${region}">
            ${vivillonSVG(region, 20)}
            <span>${region}</span>
            <i class="fa-solid fa-check check-icon"></i>
          </div>
        `;
      }).join('');

      container.querySelectorAll('.multiselect-option').forEach(el => {
        el.addEventListener('click', () => {
          const region = el.dataset.region;
          const idx = selectedValues.indexOf(region);
          if (idx > -1) {
            selectedValues.splice(idx, 1);
            el.classList.remove('selected');
          } else {
            selectedValues.push(region);
            el.classList.add('selected');
          }
        });
      });
    }

    function renderRegionChips() {
      const container = document.getElementById('regionChips');
      const counts = {};
      regionNames.forEach(r => { counts[r] = 0; });
      state.trainers.forEach(t => { counts[t.homeRegion] = (counts[t.homeRegion] || 0) + 1; });

      container.innerHTML = regionNames.map(region => {
        const active = state.filters.regions.includes(region);
        return `
          <div class="region-chip ${active ? 'active' : ''}" data-region="${region}">
            ${vivillonSVG(region, 22)}
            <span>${region}</span>
            <span class="region-chip-count">${counts[region] || 0}</span>
          </div>
        `;
      }).join('');

      container.querySelectorAll('.region-chip').forEach(el => {
        el.addEventListener('click', () => {
          const region = el.dataset.region;
          const idx = state.filters.regions.indexOf(region);
          if (idx > -1) state.filters.regions.splice(idx, 1);
          else state.filters.regions.push(region);
          state.currentPage = 1;
          renderRegionChips();
          renderRegionProgress();
          renderTrainers();
          updateClearFiltersBtn();
        });
      });
    }

    function renderRegionProgress() {
      const container = document.getElementById('regionProgressList');
      const counts = {};
      regionNames.forEach(r => { counts[r] = 0; });
      state.trainers.forEach(t => {
        if (t.status === 'available') counts[t.homeRegion] = (counts[t.homeRegion] || 0) + 1;
      });

      container.innerHTML = regionNames.map(region => {
        const completed = state.completedRegions.has(region);
        const active = state.filters.regions.includes(region);
        return `
          <div class="region-progress-item ${completed ? 'completed' : ''} ${active ? 'active' : ''}" data-region="${region}">
            ${vivillonSVG(region, 26)}
            <div class="region-progress-info">
              <div class="region-progress-name">${region}</div>
              <div class="region-progress-count">${counts[region]} online</div>
            </div>
            <div class="region-progress-check">
              <i class="fa-solid fa-check"></i>
            </div>
          </div>
        `;
      }).join('');

      container.querySelectorAll('.region-progress-item').forEach(el => {
        el.addEventListener('click', () => {
          const region = el.dataset.region;
          const idx = state.filters.regions.indexOf(region);
          if (idx > -1) state.filters.regions.splice(idx, 1);
          else state.filters.regions.push(region);
          state.currentPage = 1;
          renderRegionChips();
          renderRegionProgress();
          renderTrainers();
          updateClearFiltersBtn();
        });
      });
    }

    function getFilteredTrainers() {
      let results = [...state.trainers];
      if (state.filters.search) {
        const q = state.filters.search.toLowerCase().replace(/\s/g, '');
        results = results.filter(t => {
          const fc = t.friendCode.replace(/\s/g, '');
          return t.username.toLowerCase().includes(q) || fc.includes(q);
        });
      }
      if (state.filters.regions.length > 0) {
        results = results.filter(t => state.filters.regions.includes(t.homeRegion));
      }
      switch (state.filters.sort) {
        case 'newest': results.sort((a, b) => b.createdAt - a.createdAt); break;
        case 'recently-active': results.sort((a, b) => b.lastSeen - a.lastSeen); break;
        case 'most-wanted': results.sort((a, b) => b.lookingFor.length - a.lookingFor.length); break;
        case 'alphabetical': results.sort((a, b) => a.username.localeCompare(b.username)); break;
      }
      return results;
    }

    function renderSkeletonCards(count = 6) {
      const grid = document.getElementById('trainerGrid');
      grid.innerHTML = Array(count).fill(0).map(() => `
        <div class="skeleton-card">
          <div style="display:flex;gap:12px;">
            <div class="skeleton skel-avatar"></div>
            <div style="flex:1;">
              <div class="skeleton skel-line sm" style="margin-bottom:8px;"></div>
              <div class="skeleton skel-line" style="height:10px;width:50%;"></div>
            </div>
          </div>
          <div class="skeleton skel-line lg" style="height:36px;border-radius:4px;"></div>
          <div class="skeleton skel-line md"></div>
          <div class="skeleton skel-line lg"></div>
          <div style="display:flex;gap:8px;">
            <div class="skeleton skel-btn" style="flex:1;"></div>
            <div class="skeleton skel-btn" style="flex:1;"></div>
          </div>
        </div>
      `).join('');
    }

    function renderEmptyState() {
      document.getElementById('trainerGrid').innerHTML = `
        <div style="grid-column: 1 / -1; text-align: center; padding: 60px 20px;">
          <i class="fa-solid fa-gift" style="font-size: 48px; color: var(--muted); opacity: 0.5; margin-bottom: 20px;"></i>
          <h3 style="font-family: var(--font-head); font-size: 24px; text-transform: uppercase; margin-bottom: 8px;">No trainers found</h3>
          <p style="color: var(--muted); margin-bottom: 20px;">No trainers currently available from this region.</p>
          <button class="btn-outline-sm" id="emptyClearFilters" style="display: inline-flex; flex: none; padding: 10px 20px;">Clear Filters</button>
        </div>
      `;
      document.getElementById('emptyClearFilters').addEventListener('click', clearAllFilters);
      document.getElementById('pagination').innerHTML = '';
    }

    function renderTrainerCard(trainer) {
      const sent = state.sentRequests.has(trainer.id);
      return `
        <article class="trainer-card ${sent ? 'request-sent' : ''}" data-id="${trainer.id}">
          <div class="trainer-header">
            <div class="trainer-avatar" style="background: linear-gradient(135deg, ${trainer.avatarColor}, ${trainer.avatarColor}99);">
              ${trainer.avatarInitial}
              <span class="status-dot ${trainer.status}"></span>
            </div>
            <div>
              <div class="trainer-name">${trainer.username}</div>
              <div class="trainer-meta">
                <i class="fa-regular fa-clock"></i> ${formatLastSeen(trainer.lastSeen)} · ${statusLabel(trainer.status)}
              </div>
            </div>
          </div>

          <div class="trainer-fc">
            <div class="fc-text">${trainer.friendCode}</div>
            <button class="icon-btn copy-code-btn" data-code="${trainer.friendCode}" style="border: none; padding: 4px;">
              <i class="fa-solid fa-copy"></i>
            </button>
          </div>

          <div class="trainer-details">
            <div class="detail-row">
              <span class="detail-label">Region</span>
              <span class="detail-value">${vivillonSVG(trainer.homeRegion, 18)} ${trainer.homeRegion}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Looking For</span>
              <span class="detail-value">
                ${trainer.lookingFor.map(r => `<span class="region-tag">${vivillonSVG(r, 16)} ${r}</span>`).join('')}
              </span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Country</span>
              <span class="detail-value">${trainer.country}</span>
            </div>
          </div>

          <div class="trainer-actions">
            <button class="btn-outline-sm copy-code-btn" data-code="${trainer.friendCode}">
              <i class="fa-solid fa-copy"></i> Copy Code
            </button>
            ${sent
              ? `<button class="btn-sent-sm" disabled><i class="fa-solid fa-check"></i> Request Sent</button>`
              : `<button class="btn-grad-sm add-friend-btn" data-id="${trainer.id}"><i class="fa-solid fa-user-plus"></i> I've Added You</button>`
            }
          </div>
        </article>
      `;
    }

    function renderTrainers() {
      const grid = document.getElementById('trainerGrid');
      const filtered = getFilteredTrainers();
      const total = filtered.length;
      const totalPages = Math.ceil(total / state.perPage);
      if (state.currentPage > totalPages && totalPages > 0) state.currentPage = totalPages;
      if (totalPages === 0) state.currentPage = 1;

      const start = (state.currentPage - 1) * state.perPage;
      const pageItems = filtered.slice(start, start + state.perPage);

      document.getElementById('resultCount').textContent = total.toLocaleString();

      if (total === 0) {
        renderEmptyState();
        return;
      }

      grid.innerHTML = pageItems.map(renderTrainerCard).join('');

      grid.querySelectorAll('.copy-code-btn').forEach(btn => {
        btn.addEventListener('click', () => copyToClipboard(btn.dataset.code, 'Friend code copied!'));
      });

      grid.querySelectorAll('.add-friend-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.id;
          state.sentRequests.add(id);
          const card = btn.closest('.trainer-card');
          card.classList.add('request-sent');
          btn.outerHTML = `<button class="btn-sent-sm" disabled><i class="fa-solid fa-check"></i> Request Sent</button>`;
          showToast('Friend request sent! Remember to send a gift soon.', 'success');
        });
      });

      renderPagination(totalPages);
    }

    function renderPagination(totalPages) {
      const container = document.getElementById('pagination');
      if (totalPages <= 1) { container.innerHTML = ''; return; }
      let html = `<button class="page-btn" ${state.currentPage === 1 ? 'disabled' : ''} data-page="${state.currentPage - 1}"><i class="fa-solid fa-chevron-left"></i></button>`;
      const startPage = Math.max(1, state.currentPage - 2);
      const endPage = Math.min(totalPages, startPage + 4);
      for (let i = startPage; i <= endPage; i++) {
        html += `<button class="page-btn ${i === state.currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`;
      }
      html += `<button class="page-btn" ${state.currentPage === totalPages ? 'disabled' : ''} data-page="${state.currentPage + 1}"><i class="fa-solid fa-chevron-right"></i></button>`;
      container.innerHTML = html;
      container.querySelectorAll('.page-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const page = parseInt(btn.dataset.page);
          if (!isNaN(page) && page >= 1 && page <= totalPages) {
            state.currentPage = page;
            renderTrainers();
            document.querySelector('.main-content').scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    }

    function updateClearFiltersBtn() {
      const btn = document.getElementById('clearFilters');
      const hasFilters = state.filters.search || state.filters.regions.length > 0;
      btn.style.display = hasFilters ? 'inline-flex' : 'none';
    }

    function clearAllFilters() {
      state.filters.search = '';
      state.filters.regions = [];
      state.currentPage = 1;
      document.getElementById('searchInput').value = '';
      renderRegionChips();
      renderRegionProgress();
      renderTrainers();
      updateClearFiltersBtn();
      showToast('Filters cleared', 'info');
    }

    /* ============================================================
       MODAL LOGIC
       ============================================================ */
    const modal = document.getElementById('addFriendModal');

    function buildModalForm() {
      const body = document.getElementById('modalBody');
      const footer = document.getElementById('modalFooter');
      footer.style.display = 'flex';
      body.innerHTML = `
        <form id="addFriendForm" novalidate>
          <div class="form-group">
            <label class="form-label">Username <span style="color: #ef4444;">*</span></label>
            <input type="text" class="form-input" id="fUsername" placeholder="Trainer123" maxlength="20" required>
            <div class="form-error" id="errUsername">Please enter a username.</div>
          </div>
          <div class="form-group">
            <label class="form-label">Friend Code <span style="color: #ef4444;">*</span></label>
            <input type="text" class="form-input" id="fFriendCode" placeholder="1234 5678 9012" maxlength="14" required>
            <div class="form-error" id="errFriendCode">Friend code must be in format: XXXX XXXX XXXX</div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Home Region <span style="color: #ef4444;">*</span></label>
              <select class="form-select" id="fHomeRegion" required>
                <option value="">Select region...</option>
                ${regionNames.map(r => `<option value="${r}">${r}</option>`).join('')}
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Country <span style="color: #ef4444;">*</span></label>
              <select class="form-select" id="fCountry" required>
                <option value="">Select country...</option>
                ${allCountries.map(c => `<option value="${c}">${c}</option>`).join('')}
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Looking For (select all that apply)</label>
            <div class="multiselect-box" id="fLookingFor" style="max-height: 120px;"></div>
          </div>
          <div class="form-group">
            <label class="form-label">Short Note</label>
            <textarea class="form-textarea" id="fNote" placeholder="Daily gift sender" maxlength="120"></textarea>
          </div>
          <div class="form-check">
            <input type="checkbox" id="fAgree" required>
            <label for="fAgree">I agree my friend code will be publicly visible to other trainers on PogoRaids.</label>
          </div>
          <div class="form-error" id="errAgree" style="margin-top:6px;">You must agree to share your friend code.</div>
        </form>
      `;
      renderMultiSelect('fLookingFor', []);
      attachFormValidation();
    }

    function openModal() {
      buildModalForm();
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
      setTimeout(() => document.getElementById('fUsername').focus(), 100);
    }

    function closeModal() {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    }

    function showSuccessState() {
      const body = document.getElementById('modalBody');
      const footer = document.getElementById('modalFooter');
      footer.style.display = 'none';
      body.innerHTML = `
        <div class="modal-success">
          <div class="success-icon"><i class="fa-solid fa-check"></i></div>
          <h2 class="modal-title" style="margin-bottom: 8px;">Profile Created!</h2>
          <p style="color: var(--muted); margin-bottom: 24px;">Your trainer card is now visible to trainers around the world.</p>
          <button class="btn-primary" id="successDone" style="display: inline-flex;">View My Profile</button>
        </div>
      `;
      document.getElementById('successDone').addEventListener('click', closeModal);
    }

    function attachFormValidation() {
      const fcInput = document.getElementById('fFriendCode');
      if (fcInput) {
        fcInput.addEventListener('input', (e) => {
          let val = e.target.value.replace(/\D/g, '').slice(0, 12);
          const parts = [];
          for (let i = 0; i < val.length; i += 4) parts.push(val.slice(i, i + 4));
          e.target.value = parts.join(' ');
        });
      }
    }

    function validateAndSubmit() {
      const username = document.getElementById('fUsername').value.trim();
      const friendCode = document.getElementById('fFriendCode').value.trim();
      const homeRegion = document.getElementById('fHomeRegion').value;
      const country = document.getElementById('fCountry').value;
      const agree = document.getElementById('fAgree').checked;
      let valid = true;

      const errUsername = document.getElementById('errUsername');
      const fUsername = document.getElementById('fUsername');
      if (!username) {
        errUsername.classList.add('visible'); fUsername.classList.add('error'); valid = false;
      } else { errUsername.classList.remove('visible'); fUsername.classList.remove('error'); }

      const errFriendCode = document.getElementById('errFriendCode');
      const fFriendCode = document.getElementById('fFriendCode');
      if (!/^\d{4}\s\d{4}\s\d{4}$/.test(friendCode)) {
        errFriendCode.textContent = 'Friend code must be in format: XXXX XXXX XXXX';
        errFriendCode.classList.add('visible'); fFriendCode.classList.add('error'); valid = false;
      } else if (state.trainers.some(t => t.friendCode === friendCode)) {
        errFriendCode.textContent = 'This friend code is already registered.';
        errFriendCode.classList.add('visible'); fFriendCode.classList.add('error'); valid = false;
      } else { errFriendCode.classList.remove('visible'); fFriendCode.classList.remove('error'); }

      const errAgree = document.getElementById('errAgree');
      if (!agree) { errAgree.classList.add('visible'); valid = false; } else { errAgree.classList.remove('visible'); }

      if (!valid) { showToast('Please fix the errors in the form.', 'error'); return; }

      showToast('Submitting...', 'info');
      setTimeout(() => {
        state.myProfile.friendCode = friendCode;
        state.myProfile.homeRegion = homeRegion || state.myProfile.homeRegion;
        state.myProfile.country = country || state.myProfile.country;
        document.getElementById('myFriendCode').textContent = friendCode;
        document.getElementById('myRegion').value = state.myProfile.homeRegion;
        showSuccessState();
      }, 800);
    }

    /* ============================================================
       INITIALIZATION
       ============================================================ */
    function init() {
      populateRegionSelects();
      renderMultiSelect('lookingForSelect', state.myProfile.lookingFor);
      renderRegionChips();
      renderRegionProgress();
      renderSkeletonCards(6);

      // Simulate data loading
      setTimeout(() => {
        state.trainers = generateMockTrainers(80);
        renderRegionChips();
        renderRegionProgress();
        renderTrainers();
      }, 1000);

      // Search
      document.getElementById('searchInput').addEventListener('input', debounce((e) => {
        state.filters.search = e.target.value;
        state.currentPage = 1;
        renderTrainers();
        updateClearFiltersBtn();
      }, 300));

      // Sort
      document.getElementById('sortSelect').addEventListener('change', (e) => {
        state.filters.sort = e.target.value;
        state.currentPage = 1;
        renderTrainers();
      });

      // Clear Filters
      document.getElementById('clearFilters').addEventListener('click', clearAllFilters);

      // My Region change
      document.getElementById('myRegion').addEventListener('change', (e) => {
        state.myProfile.homeRegion = e.target.value;
      });

      // Copy my code
      document.getElementById('copyMyCode').addEventListener('click', () => {
        copyToClipboard(state.myProfile.friendCode, 'Your friend code copied!');
      });

      // Edit my code
      document.getElementById('editMyCode').addEventListener('click', openModal);

      // Save profile
      document.getElementById('saveProfile').addEventListener('click', () => {
        showToast('Profile saved successfully!', 'success');
      });

      // Hero CTA
      document.getElementById('heroAddBtn').addEventListener('click', openModal);

      // Modal events
      document.getElementById('modalClose').addEventListener('click', closeModal);
      document.getElementById('modalCancel').addEventListener('click', closeModal);
      document.getElementById('modalSubmit').addEventListener('click', validateAndSubmit);
      modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('active')) closeModal();
      });

      // Availability toggle
      document.querySelectorAll('.radio-option').forEach(opt => {
        opt.addEventListener('click', () => {
          document.querySelectorAll('.radio-option').forEach(o => o.classList.remove('active'));
          opt.classList.add('active');
          state.myProfile.status = opt.dataset.status;
        });
      });

      // Animate stats
      document.querySelectorAll('[data-target]').forEach(el => {
        const target = parseInt(el.dataset.target);
        const duration = 1500;
        const start = performance.now();
        function update(now) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.floor(target * eased).toLocaleString();
          if (progress < 1) requestAnimationFrame(update);
        }
        requestAnimationFrame(update);
      });

      // Language bar toggle (visual only)
      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
        });
      });
    }

    document.addEventListener('DOMContentLoaded', init);
  </script>
